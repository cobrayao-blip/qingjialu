    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "node-edge-tts": "^1.2.10",
    "pg": "^8.20.0",
    "react": "^19.0.0",
