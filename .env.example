# 后端服务（中国大模型 · 阿里云通义）
# 在 https://dashscope.console.aliyun.com/apiKey 创建 API Key
DASHSCOPE_API_KEY="your_dashscope_api_key"

# 后端端口（默认 3001）
PORT=3001

# Node 环境：本地开发可不设；生产建议 production
# NODE_ENV=production

# PostgreSQL（与 docker-compose 中 db 服务一致时可照抄）
# Windows 本地开发若连库失败，可显式使用 127.0.0.1（后端也会在 win32+localhost 时自动改为 127.0.0.1）
PG_HOST=localhost
PG_PORT=5432
PG_USER=qingjialu
PG_PASSWORD=qingjialu
PG_DATABASE=qingjialu
#
# —— Docker Compose 开发（docker-compose.yml）——
# · 容器 api 连容器 db：走 Docker 内网，目标端口永远是库进程在容器内的 5432；compose 里已写死 PG_HOST=db、PG_PORT=5432。
# · 切勿把 PG_PORT 改成 5438 除非你真的把 compose 里 db 的端口映射改成了 "5438:5432" 且你是在「宿主机」跑 npm run dev:server
#   此时 PG_HOST=127.0.0.1、PG_PORT=5438 才表示「主机 5438 → 容器内 5432」。
# · 若本机 5432 被占用，应改 docker-compose.yml 里 db 的 ports（例如 "5438:5432"），而不是臆测库在 5438 上监听。

# 管理后台账号登录（JWT + RBAC）
# 生产务必改为强随机串；勿留空或仅空格（会导致登录接口 500）
JWT_SECRET="replace-with-a-strong-random-secret"
# 可选：服务启动时自动创建/更新首个管理员账号
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="change_me_strong_password"

# 前端：生产构建且前后端不同域时，设为后端根地址（须带协议，不要末尾斜杠）
# 构建命令示例：VITE_API_BASE=https://api.example.com npm run build
# VITE_API_BASE=

# 前端开发：Vite 代理后端地址（仅 dev/preview 有效，见 vite.config.ts）
# VITE_PROXY_TARGET=http://127.0.0.1:3001

# Docker 生产 Compose 专用环境文件模板：见 .env.docker.prod.example
