# 复制为 .env.docker.prod（勿提交 git），供：
#   docker compose -f docker-compose.prod.yml --env-file .env.docker.prod up -d --build

# ---------- 数据库（与 compose 中 db 服务一致）----------
PG_USER=qingjialu
PG_DATABASE=qingjialu
PG_PASSWORD=改为强密码

# PostgreSQL 数据目录：宿主机路径（推荐放在已挂载的 /data 数据盘上）
PGDATA_HOST_PATH=/data/qjl/pgdata

# ---------- 应用密钥 ----------
JWT_SECRET=用_openssl_rand_-hex_32_生成

# 首次登录管理员（生产强烈建议填写，否则可能无法登录站点）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=改为强密码

# 可选：DashScope 默认 Key（也可仅在网页「大模型」中配置）
# DASHSCOPE_API_KEY=

# Web 对外端口（默认 80；此变量只填写“宿主机端口”或“宿主机IP:端口”）
# WEB_PORT=80

# 当需要映射为「仅本机可访问的 8080」供宿主 Nginx 反代 HTTPS 时，可写：
# WEB_PORT=127.0.0.1:8080
